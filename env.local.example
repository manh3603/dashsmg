# Sao chép thành .env.local (cùng cấp package.json). Không commit .env / .env.local.
#
# URL API backend (có thể public). Không đặt API key hay mật khẩu vào biến NEXT_PUBLIC_*
# vì chúng lộ trong bundle trình duyệt.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Tuỳ chọn SSR / proxy nội bộ (không prefix NEXT_PUBLIC_)
# BACKEND_INTERNAL_URL=http://127.0.0.1:3001
# BACKEND_PROXY_TARGET=http://127.0.0.1:3001
