# Copy to .env và điền giá trị từ hợp đồng / đối tác.

PORT=3001
# Production: danh sách origin frontend. Dev: mặc định phản chiếu Origin (tiện LAN); bật CORS_STRICT=1 để chỉ dùng danh sách dưới.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# CORS_STRICT=1

# Lắng nghe mọi giao diện mạng (mặc định 0.0.0.0). Chỉ localhost: BIND_HOST=127.0.0.1
# BIND_HOST=0.0.0.0

# Đăng nhập demo — bắt buộc (mật khẩu không còn trong mã nguồn)
DEMO_AUTH_ADMIN_PASSWORD=
DEMO_AUTH_LABEL_PASSWORD=
DEMO_AUTH_ARTIST_PASSWORD=

# --- ACRCloud (QC — nhận diện nhạc từ URL master) ---
# Dev không có key: ACRCLOUD_MOCK=1 → /health báo acrIdentify: true, API QC không gọi ACR (mặc định «không khớp»).
# ACRCLOUD_MOCK_SYNTHETIC_HIT=1 — cùng lúc MOCK: giả lập khớp theo tiêu đề/nghệ sĩ gửi kèm request QC (chỉ để test UI).
# Bản đã phát hành thật: tắt MOCK, điền key + ACRCLOUD_HOST đúng console ACRCloud.
# ACRCLOUD_MOCK=0
#
# Host identify theo project (ví dụ identify-eu-west-1.acrcloud.com, identify-us-west-2.acrcloud.com)
# ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
# ACRCLOUD_ACCESS_KEY=
# ACRCLOUD_ACCESS_SECRET=
# Giới hạn byte tải về làm mẫu (mặc định ~2.4MB — đủ ~15–20s MP3 128k)
# ACRCLOUD_MAX_SAMPLE_BYTES=2400000
# ACRCLOUD_DOWNLOAD_TIMEOUT_MS=45000
# true = trả thêm JSON đầy đủ từ ACR trong response API (debug)
# ACRCLOUD_RETURN_RAW_JSON=false

# URL công khai của API (dùng trong link file upload — bắt buộc khi DSP cần tải master từ URL)
# Ví dụ https://api.yourlabel.com  (không có slash cuối)
# PUBLIC_BACKEND_URL=

# Giới hạn upload (MB)
# UPLOAD_MAX_AUDIO_MB=250
# UPLOAD_MAX_COVER_MB=25

# Phiên bản thông điệp: 382 (ERN 3.8.2, mặc định — theo hướng dẫn tích hợp) hoặc 43 (ERN 4.3)
# DDEX_ERN_VERSION=382
# Đối tác có thể chỉ dùng tập lãnh thổ đầu tiên như Worldwide — backend vẫn gửi TerritoryCode theo release (CIS/VN/…).

# Thời lượng track ISO 8601 khi metadata chưa có durationIso8601 (ERN 3.82 yêu cầu Duration)
# DDEX_DEFAULT_AUDIO_DURATION_PT=PT3M30.000S

# Thêm deal User Generated Video (CommercialModelType UserDefined) — true/false
# DDEX_INCLUDE_UGV_DEAL=false
# Namespace cho CommercialModelType UGV (theo hợp đồng đối tác)
# DDEX_UGV_COMMERCIAL_MODEL_NAMESPACE=DPID:DDEX_DNK

# Người gửi / nhận mặc định ERN đơn (export không-CIS) — bắt buộc khi gọi API xuất XML
DDEX_MESSAGE_SENDER_PARTY_ID=
DDEX_MESSAGE_SENDER_NAME=
DDEX_MESSAGE_RECIPIENT_PARTY_ID=
# DDEX_MESSAGE_RECIPIENT_NAME=Aggregator

# PADPIDA người nhận từng cửa hàng CIS (bắt buộc đúng với hợp đồng; export CIS báo lỗi nếu thiếu mã cửa hàng đã chọn)
DDEX_PARTY_VK_ID=
DDEX_PARTY_VK_NAME=VK Music
DDEX_PARTY_YANDEX_ID=
DDEX_PARTY_YANDEX_NAME=Yandex Music
DDEX_PARTY_ZVUK_ID=
DDEX_PARTY_ZVUK_NAME=ZVUK
DDEX_PARTY_KION_ID=
DDEX_PARTY_KION_NAME=Kion Music
DDEX_PARTY_ZING_ID=
DDEX_PARTY_ZING_NAME=Zing MP3

# --- SFTP đối tác (đẩy file DDEX — cấu hình theo deal; triển khai job ngoài UI) ---
# DDEX_SFTP_HOST=
# DDEX_SFTP_PORT=22
# DDEX_SFTP_USER=
# DDEX_SFTP_PASSWORD=
# DDEX_SFTP_REMOTE_DIR=/incoming

# --- Gửi ERN lên endpoint đối tác (POST) ---
# Nếu đặt URL, backend sẽ POST body XML (application/xml) hoặc JSON tùy BODY_MODE.
# Store không có URL: chỉ ghi file, không gọi HTTP.
#
# VK Music
CIS_DELIVERY_VK_MUSIC_URL=
CIS_DELIVERY_VK_MUSIC_API_KEY=
# Tuỳ chọn: tên header thay vì Authorization Bearer (ví dụ X-Partner-Key)
# CIS_DELIVERY_VK_MUSIC_AUTH_HEADER=X-Api-Key
# Tuỳ chọn: json → body { "ern43Xml": "<xml...>", "format": "ddex-ern-43" }
# CIS_DELIVERY_VK_MUSIC_BODY_MODE=json

CIS_DELIVERY_YANDEX_MUSIC_URL=
CIS_DELIVERY_YANDEX_MUSIC_API_KEY=

CIS_DELIVERY_ZVUK_URL=
CIS_DELIVERY_ZVUK_API_KEY=

CIS_DELIVERY_KION_MUSIC_URL=
CIS_DELIVERY_KION_MUSIC_API_KEY=

# Zing MP3 (Việt Nam)
CIS_DELIVERY_ZING_MP3_URL=
CIS_DELIVERY_ZING_MP3_API_KEY=

# Timeout mỗi lần gọi (ms)
# CIS_DELIVERY_TIMEOUT_MS=120000

# true = batch DDEX hằng ngày (pending_qc) tự ghi file + POST lên mọi URL đã cấu hình
CIS_AUTO_DELIVERY=false

DDEX_OUTPUT_DIR=./data/ddex-out
# DDEX_DAILY_CRON=0 2 * * *
